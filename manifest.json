{
  "manifest_version": 3,
  "name": "AI & Tech News Homepage",
  "version": "1.1",
  "description": "Replace Chrome's new tab page with AI & Tech news from Anthropic, OpenAI, DeepMind, and more, plus Google Calendar integration",
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://venturebeat.com/*",
    "https://huggingface.co/*",
    "https://www.alignmentforum.org/*",
    "https://openai.com/*",
    "https://deepmind.google/*",
    "https://www.deepmind.com/*",
    "https://arstechnica.com/*",
    "https://thegradient.pub/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "103842373196-oi1i1m8281fm3icd6h4sm2mbf86i7ei4.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/tasks"
    ]
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icon16.png",
    "512": "icon512.png"
  }
}